jtml 2

use appState from "../../stores/app-state.jtml"
use AppHeader from "../ui/app-header.jtml"
use AppSidebar from "../ui/app-sidebar.jtml"
use AlertBar from "../ui/common.jtml"

export make Shell title
  page class "ops-app"
    box class "ops-shell"
      AppSidebar
      box class "ops-content"
        AppHeader title
        main class "ops-main"
          if appState.alertMessage != ""
            AlertBar appState.alertMessage
          slot
