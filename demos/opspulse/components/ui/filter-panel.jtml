jtml 2

use filterState from "../../stores/filter-state.jtml"

when filterRegionAll
  filterState.selectedRegion = "All"

when filterRegionPortugal
  filterState.selectedRegion = "Portugal"

when filterRegionSpain
  filterState.selectedRegion = "Spain"

when filterRegionBrazil
  filterState.selectedRegion = "Brazil"

when filterPlatformAll
  filterState.selectedPlatform = "All"

when filterPlatformWeb
  filterState.selectedPlatform = "Web"

when filterPlatformMobile
  filterState.selectedPlatform = "Mobile"

when filterPlatformInternal
  filterState.selectedPlatform = "Internal"

when filterToolAll
  filterState.selectedTool = "All"

when filterToolChatGPT
  filterState.selectedTool = "ChatGPT"

when filterToolCopilot
  filterState.selectedTool = "Copilot"

when filterToolClaude
  filterState.selectedTool = "Claude"

export make FilterPanel
  box class "ops-card"
    strong "Operational filters"
    box class "toolbar"
      button "All regions" click filterRegionAll
      button "Portugal" click filterRegionPortugal
      button "Spain" click filterRegionSpain
      button "Brazil" click filterRegionBrazil
    box class "toolbar"
      button "All platforms" click filterPlatformAll
      button "Web" click filterPlatformWeb
      button "Mobile" click filterPlatformMobile
      button "Internal" click filterPlatformInternal
    box class "toolbar"
      button "All tools" click filterToolAll
      button "ChatGPT" click filterToolChatGPT
      button "Copilot" click filterToolCopilot
      button "Claude" click filterToolClaude
    text "Current filter: {filterState.selectedRegion} / {filterState.selectedPlatform} / {filterState.selectedTool}"
