jtml 2
let tasks = [{ "title": "Buy groceries", "done": false }, { "title": "Pay bills", "done": false }, { "title": "Feed cat", "done": true }]

when markDone taskIndex
  let tasks[taskIndex]["done"] = true

box class "tasks-container"
  show "Tasks"
  for i in 0..tasks.size() - 1
    box class "task-item" click markDone(i)
      if tasks[i]["done"] == true
        show "[DONE] " + tasks[i]["title"]
      else
        show "[TODO] " + tasks[i]["title"]
