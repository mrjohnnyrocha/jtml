jtml 2

store auth
  let user: string = "Ada"
  let token = "demo-token"

  when logout
    let user = ""
    let token = ""

page class "store-demo" style "max-width: 680px; margin: 48px auto; padding: 28px; font-family: Arial, sans-serif; display: grid; gap: 14px"
  h1 "Store state"
  if auth.user
    text "Signed in as {auth.user}"
    button "Logout" click auth.logout
  else
    text "Signed out"
