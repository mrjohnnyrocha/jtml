jtml 2
let siteTitle = "JTML Example"
let mainColor = "blue"

html
  head
    title
      show siteTitle
  body style "background: #fafafa" class "rootBody"
    show "Hello from the body"
    section style "margin: 20px; padding: 10px; border: 1px solid #dadada"
      show "Inside a section with color: " + mainColor
    show "End of main content."
